@model FzCommon.Map.MapMetadata

@{
  Layout = "_AdminLayout";
  ViewData["Title"] = "Map Cache Info";

  (int gridCount, int tileCount, int totalSize) mapCacheStats = MapCache.Get().GetCacheStats(Model.RegionId);
}

<partial name="_showMessage" />
<div class="row">
  <div class="col-lg-12 col-md-12 col-xs-12 col-sm-12">
    <div class="card card-info">
      <div class="card-header">
        <div class="card-title">Map Cache Info for @ViewBag.Region.RegionName</div>
      </div>
    </div>
  </div>
</div>

<div style="height:10px;"></div>

@if (TempData.ContainsKey("precacheResult"))
{
<div class="row">
  <div class="col-lg-12 col-md-12 col-xs-12 col-sm-12">
    <div class="card card-info">
      <div class="card-body">
        Precache results: @TempData["precacheResult"]
      </div>
    </div>
  </div>
</div>
}

<div class="row">
  <div class="col-lg-12 col-md-12 col-xs-12 col-sm-12">
    <div class="card card-info">
      <div class="card-body">
        Map cache has @mapCacheStats.gridCount grid entries, with @mapCacheStats.tileCount unique tiles (@mapCacheStats.totalSize bytes worth of gzipped data).
        <a href="/regions/CacheInfo/@Model.RegionId?precache=true">Precache</a>
      </div>
    </div>
  </div>
</div>

