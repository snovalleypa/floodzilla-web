@model FzCommon.Map.MapMetadata

@{
  Layout = "_AdminLayout";
  ViewData["Title"] = "Edit Map Metadata";
}
<partial name="_showMessage" />
<div class="row">
  <div class="col-lg-12 col-md-12 col-xs-12 col-sm-12">
    <div class="card card-info">
      <div class="card-header">
        <div class="card-title">Map Metadata for @ViewBag.Region.RegionName (<a href="/regions/CacheInfo/@Model.RegionId">Tile Cache Info</a>)</div>
      </div>
    </div>
  </div>
</div>
<div style="height:10px;"></div>
<form asp-action="MapMetadata" class="form-horizontal" method="post" autocomplete="off">
  <input type="hidden" asp-for="RegionId" />

  <div class="form-group row">
    <div class="col-md-2 control-label">
      <label asp-for="RefererList" class="control-label">Valid Referers:</label>
    </div>
    <div class="col-md-10">
      <input type="text" asp-for="RefererList" class="form-control" />
    </div>
  </div>
  <div class="form-group row">
    <div class="col-md-2 control-label">
      <label asp-for="SlugList" class="control-label">Valid App Slugs:</label>
    </div>
    <div class="col-md-10">
      <input type="text" asp-for="SlugList" class="form-control" />
    </div>
  </div>

  <div class="form-group row">
    <div class="col-md-2 control-label">
      <label asp-for="WebStylesRaw" class="control-label">Web Styles:</label>
    </div>
    <div class="col-md-10">
      <textarea class="form-control textarea-monospace" rows="10" cols="10" asp-for="WebStylesRaw"></textarea>
    </div>
  </div>

  <div class="form-group row">
    <div class="col-md-2 control-label">
      <label asp-for="MobileStylesRaw" class="control-label">Mobile Styles:</label>
    </div>
    <div class="col-md-10">
      <textarea class="form-control textarea-monospace" rows="10" cols="10" asp-for="MobileStylesRaw"></textarea>
    </div>
  </div>

  <div class="form-group row">
    <div class="col-md-2 control-label">
      <label asp-for="TileDescJsonRaw" class="control-label">Tile Description:</label>
    </div>
    <div class="col-md-10">
      <textarea class="form-control textarea-monospace" rows="10" cols="10" asp-for="TileDescJsonRaw"></textarea>
    </div>
  </div>


  <div class="form-group row">
    <div class="col-md-10 offset-2">
      <button type="submit" class="btn btn-primary">Save</button>
      <a asp-action="Edit/@Model.RegionId" class="btn btn-secondary">Cancel</a>
    </div>
  </div>
</form>
